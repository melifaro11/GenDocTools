# ---------------------------------------------------------------------------
# GenDocTools OpenAPI Tool Server
# ---------------------------------------------------------------------------
APP_MODE=openapi

HOST=0.0.0.0
PORT=8017

DATA_DIR=/data

# IMPORTANT:
# This URL must be reachable from the user's browser, not only from inside Docker.
# Examples:
# PUBLIC_BASE_URL=http://192.168.1.50:8017
# PUBLIC_BASE_URL=https://gendoctools.example.com
PUBLIC_BASE_URL=http://localhost:8017

APP_VERSION=0.1.0

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# Dev:
ENABLE_AUTH=false
ALLOW_ANONYMOUS=true

# Production-ish:
# ENABLE_AUTH=true
# ALLOW_ANONYMOUS=false
# TOOL_API_KEYS=change-me-token-1,change-me-token-2
TOOL_API_KEYS=

# ---------------------------------------------------------------------------
# Download URLs
# ---------------------------------------------------------------------------

# Generate this with:
# openssl rand -hex 32
DOWNLOAD_SIGNING_SECRET=change-me-long-random-secret

DOWNLOAD_TOKEN_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# Storage limits / retention
# ---------------------------------------------------------------------------
MAX_FILE_SIZE_MB=100
RETENTION_DAYS=30
